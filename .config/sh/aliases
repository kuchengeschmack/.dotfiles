alias ls='ls --color=always'
alias la='ls -a'
alias ll='la -l'
alias github='xdg-open https://github.com'
alias dot='git --git-dir="$HOME/.dotfiles" --work-tree="$HOME"'
alias ..='cd ..'
alias hx='helix'

dev(){
  if [ -n "$1" ]; then
    cd $XDG_PROJECTS_DIR/*$1*
  else
    cd $XDG_PROJECTS_DIR
  fi
}
